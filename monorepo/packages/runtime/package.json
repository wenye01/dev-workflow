    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js"
    },
    "./activation": {
      "types": "./dist/activation/index.d.ts",
      "import": "./dist/activation/index.js"
    },
    "./recipe": {
      "types": "./dist/recipe/index.d.ts",
