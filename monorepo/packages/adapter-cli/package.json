{
  "name": "@agentflow/adapter-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "agentflow-adapter-cli": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    },
    "./backends": {
      "types": "./dist/backends/index.d.ts",
      "import": "./dist/backends/index.js"
    },
    "./executor": {
      "types": "./dist/executor/index.d.ts",
      "import": "./dist/executor/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js"
    },
    "./progress": {
      "types": "./dist/progress/index.d.ts",
      "import": "./dist/progress/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --pretty false",
    "test": "pnpm build && node --test test/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --pretty false --noEmit"
  }
}
