{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["verdict", "summary", "issues"],
  "additionalProperties": false,
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "summary": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "category", "description", "location"],
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "suggestion"]
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": ["code_quality", "test_quality", "correctness", "security", "ux", "performance", "maintainability"]
          },
          "location": {
            "type": "string"
          }
        }
      }
    }
  }
}
