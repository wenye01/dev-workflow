{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["summary", "decisions"],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "action", "rationale"],
        "additionalProperties": false,
        "properties": {
          "issue_id": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": ["implement", "close"]
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    }
  }
}
