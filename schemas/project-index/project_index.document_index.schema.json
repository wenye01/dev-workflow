{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.project_index.document_index.v1",
  "title": "Project Index document index",
  "type": "object",
  "required": ["schema_version", "repo", "generated_at", "documents"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.project_index.document_index.v1" },
    "repo": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "generated_at": { "type": "string" },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "doc_id",
          "path",
          "title",
          "kind",
          "content_sha256",
          "mtime",
          "sections",
          "summary_ref",
          "related_modules"
        ],
        "additionalProperties": false,
        "properties": {
          "doc_id": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" },
          "path": { "$ref": "agentflow.schema.common.v1#/$defs/relative_path" },
          "title": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "kind": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/document_kind"
          },
          "content_sha256": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/sha256"
          },
          "mtime": { "type": "string" },
          "sections": {
            "type": "array",
            "items": {
              "$ref": "agentflow.schema.project_index.common.v1#/$defs/document_section"
            }
          },
          "summary_ref": {
            "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
          },
          "related_modules": {
            "type": "array",
            "items": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" }
          }
        }
      }
    }
  }
}
