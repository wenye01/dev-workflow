{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.project_index.document_summary.v1",
  "title": "Project Index document summary",
  "type": "object",
  "required": [
    "schema_version",
    "doc_id",
    "path",
    "title",
    "kind",
    "content_sha256",
    "mtime",
    "summary",
    "sections",
    "anchors",
    "source"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "agentflow.project_index.document_summary.v1"
    },
    "doc_id": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" },
    "path": { "$ref": "agentflow.schema.common.v1#/$defs/relative_path" },
    "title": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "kind": {
      "$ref": "agentflow.schema.project_index.common.v1#/$defs/document_kind"
    },
    "content_sha256": {
      "$ref": "agentflow.schema.project_index.common.v1#/$defs/sha256"
    },
    "mtime": { "type": "string" },
    "summary": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.project_index.common.v1#/$defs/document_section"
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
      }
    },
    "source": {
      "type": "object",
      "required": ["path", "content_sha256"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "agentflow.schema.common.v1#/$defs/relative_path" },
        "content_sha256": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/sha256"
        }
      }
    }
  }
}
