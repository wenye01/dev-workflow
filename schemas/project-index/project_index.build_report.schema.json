{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.project_index.build_report.v1",
  "title": "Project Index build report",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "generated_at",
    "status",
    "quality",
    "skipped_files",
    "missing_commands",
    "freshness",
    "degradations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.project_index.build_report.v1" },
    "repo": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "generated_at": { "type": "string" },
    "status": { "enum": ["pass", "degraded", "failed"] },
    "quality": {
      "type": "object",
      "required": ["indexed_files", "indexed_documents", "indexed_modules"],
      "additionalProperties": false,
      "properties": {
        "indexed_files": { "type": "integer", "minimum": 0 },
        "indexed_documents": { "type": "integer", "minimum": 0 },
        "indexed_modules": { "type": "integer", "minimum": 0 }
      }
    },
    "skipped_files": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.project_index.common.v1#/$defs/skip_entry"
      }
    },
    "missing_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "reason"],
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["test", "lint", "typecheck", "build"] },
          "reason": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    },
    "freshness": {
      "type": "object",
      "required": [
        "head",
        "config_hash",
        "schema_version",
        "builder_version",
        "indexed_files"
      ],
      "additionalProperties": false,
      "properties": {
        "head": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/git_head"
        },
        "config_hash": { "type": ["string", "null"] },
        "schema_version": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "builder_version": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "indexed_files": {
          "type": "array",
          "items": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/file_fingerprint"
          }
        }
      }
    },
    "degradations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason", "impact"],
        "additionalProperties": false,
        "properties": {
          "reason": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "impact": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    }
  }
}
