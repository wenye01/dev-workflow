{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.project_index.commands.v1",
  "title": "Project Index commands",
  "type": "object",
  "required": ["schema_version", "repo", "generated_at", "commands", "missing"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.project_index.commands.v1" },
    "repo": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "generated_at": { "type": "string" },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.project_index.common.v1#/$defs/command_entry"
      }
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "reason"],
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["test", "lint", "typecheck", "build"] },
          "reason": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    }
  }
}
