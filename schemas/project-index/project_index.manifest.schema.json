{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.project_index.manifest.v1",
  "title": "Project Index manifest",
  "type": "object",
  "required": [
    "schema_version",
    "index_id",
    "repo",
    "head",
    "config_hash",
    "generated_at",
    "builder",
    "schema_versions",
    "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.project_index.manifest.v1" },
    "index_id": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" },
    "repo": {
      "type": "object",
      "required": ["root"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "remote": { "type": "string" },
        "base_ref": { "type": "string" }
      }
    },
    "head": {
      "$ref": "agentflow.schema.project_index.common.v1#/$defs/git_head"
    },
    "config_hash": {
      "type": ["string", "null"]
    },
    "generated_at": { "type": "string" },
    "builder": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "version": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        }
      }
    },
    "schema_versions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "ref",
          "schema_id",
          "content_sha256",
          "size_bytes"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "kind": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref_kind"
          },
          "ref": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" },
          "schema_id": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "content_sha256": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/sha256"
          },
          "size_bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
