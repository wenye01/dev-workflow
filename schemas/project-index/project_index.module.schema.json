{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.project_index.module.v1",
  "title": "Project Index module",
  "type": "object",
  "required": [
    "schema_version",
    "module_id",
    "name",
    "summary",
    "boundaries",
    "entrypoints",
    "test_files",
    "dependencies",
    "related_commands"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.project_index.module.v1" },
    "module_id": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" },
    "name": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "summary": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "boundaries": {
      "type": "object",
      "required": ["paths"],
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.common.v1#/$defs/relative_path"
      }
    },
    "test_files": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.common.v1#/$defs/relative_path"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "target", "summary"],
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["module", "package", "runtime", "unknown"] },
          "target": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "summary": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    },
    "related_commands": {
      "type": "array",
      "items": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" }
    }
  }
}
