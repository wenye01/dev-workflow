{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.project_index.repo_tree.v1",
  "title": "Project Index repo tree",
  "type": "object",
  "required": ["schema_version", "repo", "generated_at", "entries", "skipped"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.project_index.repo_tree.v1" },
    "repo": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "generated_at": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.project_index.common.v1#/$defs/tree_entry"
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.project_index.common.v1#/$defs/skip_entry"
      }
    }
  }
}
