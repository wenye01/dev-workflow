{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.project_index.common.v1",
  "title": "Project Index common definitions",
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "git_head": {
      "type": "object",
      "required": ["sha"],
      "additionalProperties": false,
      "properties": {
        "sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,64}$"
        },
        "ref": { "type": "string" }
      }
    },
    "project_index_ref_kind": {
      "enum": [
        "manifest",
        "overview",
        "repo_tree",
        "commands",
        "module",
        "document_index",
        "document_summary",
        "build_report"
      ]
    },
    "project_index_ref": {
      "type": "object",
      "required": ["kind", "ref", "schema_id", "content_sha256"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref_kind"
        },
        "ref": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" },
        "schema_id": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "content_sha256": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/sha256"
        }
      }
    },
    "project_index_ref_set": {
      "type": "object",
      "required": ["manifest"],
      "additionalProperties": false,
      "properties": {
        "manifest": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
        },
        "overview": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
        },
        "repo_tree": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
          }
        },
        "modules": {
          "type": "array",
          "items": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
          }
        },
        "documents": {
          "type": "array",
          "items": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
          }
        },
        "document_summaries": {
          "type": "array",
          "items": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
          }
        },
        "build_report": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
        }
      }
    },
    "selected_project_context": {
      "type": "object",
      "required": ["project_index_refs"],
      "additionalProperties": false,
      "properties": {
        "project_index_refs": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref_set"
        },
        "source_slices": {
          "type": "array",
          "items": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" }
        },
        "run_artifacts": {
          "type": "array",
          "items": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" }
        },
        "feedback": {
          "type": "array",
          "items": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" }
        },
        "worktree_status": {
          "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
        },
        "context_degradation": {
          "type": "array",
          "items": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" }
        }
      }
    },
    "file_fingerprint": {
      "type": "object",
      "required": ["path", "mtime", "size_bytes", "content_sha256"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "agentflow.schema.common.v1#/$defs/relative_path" },
        "mtime": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "content_sha256": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/sha256"
        }
      }
    },
    "tree_entry": {
      "type": "object",
      "required": ["path", "kind", "size_bytes"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "agentflow.schema.common.v1#/$defs/relative_path" },
        "kind": { "enum": ["file", "directory", "symlink", "unknown"] },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "mtime": { "type": "string" },
        "content_sha256": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/sha256"
        },
        "language": { "type": "string" }
      }
    },
    "skip_entry": {
      "type": "object",
      "required": ["path", "reason"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "agentflow.schema.common.v1#/$defs/relative_path" },
        "reason": {
          "enum": [
            "gitignored",
            "dependency",
            "binary",
            "large_file",
            "log_file",
            "sensitive_path",
            "unreadable",
            "unsupported"
          ]
        },
        "detail": { "type": "string" }
      }
    },
    "command_entry": {
      "type": "object",
      "required": ["id", "kind", "command", "source", "confidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" },
        "kind": {
          "enum": ["test", "lint", "typecheck", "build", "e2e", "custom"]
        },
        "command": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "source": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "scope": {
          "type": "array",
          "items": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    },
    "document_kind": {
      "enum": [
        "readme",
        "design",
        "api",
        "config",
        "runbook",
        "changelog",
        "other"
      ]
    },
    "document_section": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "anchor": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
