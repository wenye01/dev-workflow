{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.llm.router_dispatch.v1",
  "title": "LLM router dispatch payload",
  "type": "object",
  "required": [
    "mode",
    "selected_roles",
    "execution_plan",
    "aggregation",
    "rationale"
  ],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "enum": ["initial", "fix", "re_evaluate", "plan_revision", "final"]
    },
    "selected_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "task", "context", "write_permission"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "task": {
            "type": "object",
            "required": ["goal", "scope", "non_goals"],
            "additionalProperties": false,
            "properties": {
              "goal": {
                "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
              },
              "scope": {
                "type": "array",
                "items": {
                  "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                }
              },
              "non_goals": {
                "type": "array",
                "items": {
                  "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                }
              }
            }
          },
          "context": {
            "type": "object",
            "required": [
              "modules",
              "source_paths",
              "include_artifacts",
              "include_feedback"
            ],
            "additionalProperties": false,
            "properties": {
              "modules": {
                "type": "array",
                "items": {
                  "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                }
              },
              "source_paths": {
                "type": "array",
                "items": {
                  "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                }
              },
              "include_artifacts": {
                "type": "array",
                "items": {
                  "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                }
              },
              "include_feedback": {
                "type": "array",
                "items": {
                  "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                }
              }
            }
          },
          "write_permission": {
            "description": "Prompt-level write intent for role instructions only. It is not a runtime access-control mechanism.",
            "enum": ["readonly", "artifact_write", "worktree_write"]
          },
          "provider_hint": { "type": "string" }
        }
      }
    },
    "execution_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        }
      }
    },
    "aggregation": {
      "type": "object",
      "required": ["strategy", "required_checks"],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "required_checks": {
          "type": "array",
          "items": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    },
    "rationale": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    }
  }
}
