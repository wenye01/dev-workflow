{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.context.worktree_status.v1",
  "title": "Context Builder worktree status",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "branch",
    "head",
    "clean",
    "changed_files",
    "untracked_files",
    "diff_summary",
    "commit_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.context.worktree_status.v1" },
    "repo": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "branch": { "type": ["string", "null"] },
    "head": {
      "$ref": "agentflow.schema.project_index.common.v1#/$defs/git_head"
    },
    "clean": { "type": "boolean" },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "$ref": "agentflow.schema.common.v1#/$defs/relative_path"
          },
          "status": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    },
    "untracked_files": {
      "type": "array",
      "items": { "$ref": "agentflow.schema.common.v1#/$defs/relative_path" }
    },
    "diff_summary": { "type": "string" },
    "commit_refs": {
      "type": "array",
      "items": { "$ref": "agentflow.schema.common.v1#/$defs/commit_ref" }
    }
  }
}
