{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.context.build_report.v1",
  "title": "Context Builder build report",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "status",
    "generated_at",
    "project_index",
    "quality",
    "degradations",
    "outputs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.context_build_report.v1" },
    "run_id": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "status": { "enum": ["pass", "degraded", "failed"] },
    "generated_at": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    },
    "project_index": {
      "type": "object",
      "required": ["status", "manifest_ref", "head", "config_hash"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["built", "reused"] },
        "manifest_ref": {
          "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
        },
        "head": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/git_head"
        },
        "config_hash": { "type": ["string", "null"] }
      }
    },
    "quality": {
      "type": "object",
      "required": [
        "selected_project_index_refs",
        "source_slice_files",
        "source_slice_bytes",
        "estimated_tokens",
        "missing_required_commands",
        "degradation_count"
      ],
      "additionalProperties": false,
      "properties": {
        "selected_project_index_refs": { "type": "integer", "minimum": 1 },
        "source_slice_files": { "type": "integer", "minimum": 0 },
        "source_slice_bytes": { "type": "integer", "minimum": 0 },
        "estimated_tokens": { "type": "integer", "minimum": 0 },
        "missing_required_commands": {
          "type": "array",
          "items": { "enum": ["test", "lint", "typecheck", "build"] }
        },
        "degradation_count": { "type": "integer", "minimum": 0 }
      }
    },
    "degradations": {
      "type": "array",
      "items": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" }
    },
    "outputs": {
      "type": "object",
      "required": [
        "task",
        "project_index_ref",
        "worktree_status",
        "selected_project_context",
        "source_slices",
        "role_inputs"
      ],
      "additionalProperties": false,
      "properties": {
        "task": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" },
        "project_index_ref": {
          "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
        },
        "worktree_status": {
          "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
        },
        "selected_project_context": {
          "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
        },
        "source_slices": {
          "type": "array",
          "items": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" }
        },
        "role_inputs": {
          "type": "array",
          "items": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" }
        }
      }
    }
  }
}
