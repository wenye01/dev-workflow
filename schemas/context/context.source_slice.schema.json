{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.context.source_slice.v1",
  "title": "Context Builder source slice",
  "type": "object",
  "required": [
    "schema_version",
    "slice_id",
    "role",
    "selection_basis",
    "project_index_refs",
    "files",
    "excluded_files",
    "total_bytes",
    "estimated_tokens"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.context.source_slice.v1" },
    "slice_id": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" },
    "role": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "selection_basis": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
      }
    },
    "project_index_refs": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "content_sha256",
          "size_bytes",
          "included_bytes",
          "estimated_tokens",
          "truncated",
          "excerpt"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "$ref": "agentflow.schema.common.v1#/$defs/relative_path"
          },
          "language": { "type": "string" },
          "content_sha256": {
            "$ref": "agentflow.schema.project_index.common.v1#/$defs/sha256"
          },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "included_bytes": { "type": "integer", "minimum": 0 },
          "estimated_tokens": { "type": "integer", "minimum": 0 },
          "truncated": { "type": "boolean" },
          "excerpt": { "type": "string" }
        }
      }
    },
    "excluded_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "$ref": "agentflow.schema.common.v1#/$defs/relative_path"
          },
          "reason": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    },
    "total_bytes": { "type": "integer", "minimum": 0 },
    "estimated_tokens": { "type": "integer", "minimum": 0 }
  }
}
