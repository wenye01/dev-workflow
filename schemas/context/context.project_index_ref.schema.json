{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.context.project_index_ref.v1",
  "title": "Context Builder Project Index reference",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "project_index",
    "project_index_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.context.project_index_ref.v1" },
    "generated_at": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    },
    "project_index": {
      "type": "object",
      "required": [
        "status",
        "index_id",
        "index_dir",
        "repo",
        "head",
        "config_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["built", "reused"] },
        "index_id": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" },
        "index_dir": {
          "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
        },
        "repo": {
          "type": "object",
          "required": ["root"],
          "additionalProperties": false,
          "properties": {
            "root": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "base_ref": { "type": "string" }
          }
        },
        "head": {
          "$ref": "agentflow.schema.project_index.common.v1#/$defs/git_head"
        },
        "config_hash": { "type": ["string", "null"] }
      }
    },
    "project_index_refs": {
      "$ref": "agentflow.schema.project_index.common.v1#/$defs/project_index_ref_set"
    }
  }
}
