{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.context.degradation.v1",
  "title": "Context Builder degradation",
  "type": "object",
  "required": [
    "schema_version",
    "degradation_id",
    "generated_at",
    "reason_code",
    "severity",
    "message",
    "impact",
    "affected_roles",
    "allow_continue",
    "related_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.context.degradation.v1" },
    "degradation_id": {
      "$ref": "agentflow.schema.common.v1#/$defs/ref_id"
    },
    "generated_at": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    },
    "reason_code": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    },
    "severity": { "enum": ["warning", "error"] },
    "message": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    },
    "impact": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    },
    "affected_roles": {
      "type": "array",
      "items": {
        "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
      }
    },
    "allow_continue": { "type": "boolean" },
    "related_refs": {
      "type": "array",
      "items": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" }
    }
  }
}
