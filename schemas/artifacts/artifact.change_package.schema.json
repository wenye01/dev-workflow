{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.change_package.v1",
  "title": "Change package artifact",
  "allOf": [
    { "$ref": "agentflow.schema.common.v1#/$defs/canonical_envelope" },
    {
      "type": "object",
      "required": ["unit_id", "attempt"],
      "properties": {
        "schema_version": { "const": "agentflow.change_package.v1" },
        "artifact_type": { "const": "change_package" },
        "payload": { "$ref": "agentflow.schema.llm.change_package.v1" }
      }
    }
  ]
}
