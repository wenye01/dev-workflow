{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.artifact_index.v1",
  "title": "Artifact index",
  "type": "object",
  "required": ["schema_version", "updated_at", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.artifact_index.v1" },
    "updated_at": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref",
          "artifact_type",
          "schema_version",
          "artifact_id",
          "run_id",
          "producer",
          "created_at",
          "content_sha256",
          "size_bytes",
          "commit_refs"
        ],
        "additionalProperties": false,
        "properties": {
          "ref": { "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref" },
          "artifact_type": {
            "enum": [
              "run_state",
              "unit_state",
              "artifact_index",
              "routing_decision",
              "role_run_request",
              "role_input",
              "role_output",
              "planner_package",
              "batch_schedule",
              "acceptance_contract",
              "generation_input",
              "change_package",
              "evaluation_input",
              "evaluator_report",
              "unit_decision",
              "final_report",
              "stop_report"
            ]
          },
          "schema_version": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "artifact_id": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "run_id": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "batch_id": { "type": "string" },
          "unit_id": { "type": "string" },
          "attempt": { "type": "integer", "minimum": 0 },
          "fix_round": { "type": "integer", "minimum": 0 },
          "producer": { "$ref": "agentflow.schema.common.v1#/$defs/producer" },
          "created_at": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          },
          "content_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "markdown_ref": {
            "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
          },
          "commit_refs": {
            "type": "array",
            "items": { "$ref": "agentflow.schema.common.v1#/$defs/commit_ref" }
          }
        }
      }
    }
  }
}
