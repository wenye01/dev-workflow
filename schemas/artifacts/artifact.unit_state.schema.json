{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.unit_state.v1",
  "title": "Unit state artifact",
  "type": "object",
  "required": [
    "schema_version",
    "unit_id",
    "batch_id",
    "status",
    "attempt",
    "fix_round",
    "dependencies",
    "artifacts",
    "commits",
    "pending_transition",
    "locks",
    "updated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "agentflow.unit_state.v1" },
    "unit_id": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" },
    "batch_id": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "pending",
        "ready",
        "routing_generator",
        "generating",
        "generator_aggregate",
        "evaluating",
        "evaluator_aggregate",
        "deciding",
        "passed",
        "routing_generator_fix",
        "fixing",
        "routing_evaluator",
        "plan_revision",
        "stopped"
      ]
    },
    "attempt": { "type": "integer", "minimum": 0 },
    "fix_round": { "type": "integer", "minimum": 0 },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string" }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
      }
    },
    "commits": {
      "type": "array",
      "items": { "$ref": "agentflow.schema.common.v1#/$defs/commit_ref" }
    },
    "pending_transition": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["from", "to", "artifact_ref"],
          "additionalProperties": false,
          "properties": {
            "from": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "to": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "artifact_ref": {
              "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
            }
          }
        }
      ]
    },
    "locks": {
      "type": "object",
      "required": ["file_scope"],
      "additionalProperties": false,
      "properties": {
        "file_scope": {
          "type": "array",
          "items": {
            "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
          }
        }
      }
    },
    "updated_at": {
      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
    }
  }
}
