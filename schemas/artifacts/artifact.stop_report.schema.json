{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.stop_report.v1",
  "title": "Stop report artifact",
  "allOf": [
    { "$ref": "agentflow.schema.common.v1#/$defs/canonical_envelope" },
    {
      "type": "object",
      "properties": {
        "schema_version": { "const": "agentflow.stop_report.v1" },
        "artifact_type": { "const": "stop_report" },
        "payload": {
          "type": "object",
          "required": [
            "status",
            "reason_code",
            "classification",
            "message",
            "resume_from",
            "cannot_resume_reason",
            "suggested_actions"
          ],
          "additionalProperties": true,
          "properties": {
            "status": { "const": "stopped" },
            "reason_code": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "classification": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "message": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "run_state": { "type": "object", "additionalProperties": true },
            "worktree_path": { "type": "string" },
            "branch": { "type": "string" },
            "commits": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/commit_ref"
              }
            },
            "artifact_index_ref": {
              "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
            },
            "resume_from": { "type": ["string", "null"] },
            "cannot_resume_reason": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "suggested_actions": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
              }
            }
          }
        }
      }
    }
  ]
}
