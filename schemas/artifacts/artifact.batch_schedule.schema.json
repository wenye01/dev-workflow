{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.batch_schedule.v1",
  "title": "Batch schedule artifact",
  "allOf": [
    { "$ref": "agentflow.schema.common.v1#/$defs/canonical_envelope" },
    {
      "type": "object",
      "properties": {
        "schema_version": { "const": "agentflow.batch_schedule.v1" },
        "artifact_type": { "const": "batch_schedule" },
        "payload": {
          "type": "object",
          "required": ["batches"],
          "additionalProperties": false,
          "properties": {
            "current_batch_id": { "type": "string" },
            "batches": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["batch_id", "unit_ids", "parallel"],
                "additionalProperties": false,
                "properties": {
                  "batch_id": {
                    "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                  },
                  "unit_ids": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                    }
                  },
                  "parallel": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  ]
}
