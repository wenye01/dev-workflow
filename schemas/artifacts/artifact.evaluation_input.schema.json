{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.evaluation_input.v1",
  "title": "Evaluation input artifact",
  "allOf": [
    { "$ref": "agentflow.schema.common.v1#/$defs/canonical_envelope" },
    {
      "type": "object",
      "required": ["unit_id"],
      "properties": {
        "schema_version": { "const": "agentflow.evaluation_input.v1" },
        "artifact_type": { "const": "evaluation_input" },
        "payload": {
          "type": "object",
          "required": [
            "acceptance_contract",
            "change_package",
            "changed_files",
            "verification_results"
          ],
          "additionalProperties": false,
          "properties": {
            "acceptance_contract": {
              "type": "object",
              "additionalProperties": true
            },
            "change_package": {
              "type": "object",
              "additionalProperties": true
            },
            "context": {
              "$ref": "agentflow.schema.project_index.common.v1#/$defs/selected_project_context"
            },
            "changed_files": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/changed_file"
              }
            },
            "file_snapshots": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "status"],
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "$ref": "agentflow.schema.common.v1#/$defs/relative_path"
                  },
                  "status": {
                    "enum": ["read", "missing", "skipped"]
                  },
                  "content_sha256": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                  },
                  "content_excerpt": { "type": "string" },
                  "reason": { "type": "string" }
                }
              }
            },
            "diff_summary": { "type": "string" },
            "commit_refs": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/commit_ref"
              }
            },
            "verification_results": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/verification_result"
              }
            },
            "risk_focus": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
              }
            }
          }
        }
      }
    }
  ]
}
