{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.role_run_request.v1",
  "title": "Role run request artifact",
  "allOf": [
    { "$ref": "agentflow.schema.common.v1#/$defs/canonical_envelope" },
    {
      "type": "object",
      "properties": {
        "schema_version": { "const": "agentflow.role_run_request.v1" },
        "artifact_type": { "const": "role_run_request" },
        "payload": {
          "type": "object",
          "required": [
            "request_id",
            "role",
            "task",
            "context",
            "write_permission",
            "required_output_schema"
          ],
          "additionalProperties": false,
          "properties": {
            "request_id": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "role": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "task": { "type": "object", "additionalProperties": true },
            "context": { "type": "object", "additionalProperties": true },
            "write_permission": {
              "enum": ["readonly", "artifact_write", "worktree_write"]
            },
            "provider_hint": { "type": "string" },
            "input_artifacts": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
              }
            },
            "output_artifact": {
              "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
            },
            "required_output_schema": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            }
          }
        }
      }
    }
  ]
}
