{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.acceptance_contract.v1",
  "title": "Acceptance contract artifact",
  "allOf": [
    { "$ref": "agentflow.schema.common.v1#/$defs/canonical_envelope" },
    {
      "type": "object",
      "required": ["unit_id"],
      "properties": {
        "schema_version": { "const": "agentflow.acceptance_contract.v1" },
        "artifact_type": { "const": "acceptance_contract" },
        "payload": {
          "type": "object",
          "required": [
            "objective",
            "criteria",
            "forbidden_changes",
            "evaluator_focus",
            "auto_fix_hints"
          ],
          "additionalProperties": false,
          "properties": {
            "objective": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "criteria": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "ref",
                  "description",
                  "severity",
                  "evidence_required",
                  "verification"
                ],
                "additionalProperties": false,
                "properties": {
                  "ref": { "$ref": "agentflow.schema.common.v1#/$defs/ref_id" },
                  "description": {
                    "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                  },
                  "severity": {
                    "$ref": "agentflow.schema.common.v1#/$defs/severity"
                  },
                  "evidence_required": {
                    "type": "array",
                    "items": {
                      "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                    }
                  },
                  "verification": {
                    "type": "array",
                    "items": { "type": "object", "additionalProperties": true }
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "properties": { "severity": { "const": "must" } },
                      "required": ["severity"]
                    },
                    "then": {
                      "properties": {
                        "evidence_required": { "minItems": 1 },
                        "verification": { "minItems": 1 }
                      }
                    }
                  }
                ]
              }
            },
            "forbidden_changes": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
              }
            },
            "evaluator_focus": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
              }
            },
            "auto_fix_hints": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            }
          }
        }
      }
    }
  ]
}
