{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.role_input.v1",
  "title": "Role input artifact",
  "allOf": [
    { "$ref": "agentflow.schema.common.v1#/$defs/canonical_envelope" },
    {
      "type": "object",
      "properties": {
        "schema_version": { "const": "agentflow.role_input.v1" },
        "artifact_type": { "const": "role_input" },
        "payload": {
          "type": "object",
          "required": [
            "role",
            "task",
            "context",
            "constraints",
            "required_output_schema"
          ],
          "additionalProperties": false,
          "properties": {
            "role": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "task": { "type": "object", "additionalProperties": true },
            "acceptance_contract": {
              "type": "object",
              "additionalProperties": true
            },
            "context": {
              "$ref": "agentflow.schema.project_index.common.v1#/$defs/selected_project_context"
            },
            "constraints": {
              "type": "object",
              "required": [
                "write_permission",
                "allowed_paths",
                "forbidden_paths",
                "forbidden_actions"
              ],
              "additionalProperties": true,
              "properties": {
                "write_permission": {
                  "description": "Prompt-level behavior guidance included in role constraints. It is not enforced as runtime access control.",
                  "enum": ["readonly", "artifact_write", "worktree_write"]
                },
                "allowed_paths": {
                  "type": "array",
                  "items": {
                    "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                  }
                },
                "forbidden_paths": {
                  "type": "array",
                  "items": {
                    "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                  }
                },
                "forbidden_actions": {
                  "type": "array",
                  "items": {
                    "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
                  }
                }
              }
            },
            "required_output_schema": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            }
          }
        }
      }
    }
  ]
}
