{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentflow.schema.artifact.final_report.v1",
  "title": "Final report artifact",
  "allOf": [
    { "$ref": "agentflow.schema.common.v1#/$defs/canonical_envelope" },
    {
      "type": "object",
      "properties": {
        "schema_version": { "const": "agentflow.final_report.v1" },
        "artifact_type": { "const": "final_report" },
        "payload": {
          "type": "object",
          "required": [
            "status",
            "summary",
            "unit_decisions",
            "residual_risks",
            "artifact_refs",
            "commit_refs",
            "metrics"
          ],
          "additionalProperties": false,
          "properties": {
            "status": { "const": "finalized" },
            "summary": {
              "$ref": "agentflow.schema.common.v1#/$defs/non_empty_string"
            },
            "unit_decisions": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
              }
            },
            "residual_risks": {
              "type": "array",
              "items": { "$ref": "agentflow.schema.common.v1#/$defs/risk" }
            },
            "artifact_refs": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/artifact_ref"
              }
            },
            "commit_refs": {
              "type": "array",
              "items": {
                "$ref": "agentflow.schema.common.v1#/$defs/commit_ref"
              }
            },
            "metrics": { "type": "object", "additionalProperties": true }
          }
        }
      }
    }
  ]
}
