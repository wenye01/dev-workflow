{
  "name": "agentflow",
  "version": "0.0.0",
  "description": "MVP-0 single-repository agent workflow CLI.",
  "type": "module",
  "bin": {
    "agentflow": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "fixtures",
    "schemas",
    "README.md"
  ],
  "exports": {},
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage agentflow-*.tgz",
    "dev": "tsx src/cli/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^20.17.31",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}
